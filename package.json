{
  "name": "one-holy-bible",
  "private": true,
  "version": "0.1.0",
  "description": "Local-first Bible study workbench with CUV/KJV reading and verse-linked explanatory cards",
  "author": "Siqiho",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Siqiho/one-holy-bible.git"
  },
  "bugs": {
    "url": "https://github.com/Siqiho/one-holy-bible/issues"
  },
  "homepage": "https://github.com/Siqiho/one-holy-bible#readme",
  "engines": {
    "node": ">=24 <25"
  },
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && tsc -p tsconfig.node.json --noEmit && vite build --config vite.public.config.ts",
    "generate:public-data": "node scripts/generatePublicBibleData.mjs",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "tauri": "tauri",
    "validate:public-data": "node scripts/validatePublicData.mjs public/data && node scripts/validatePublicRepository.mjs && node scripts/validatePublicRelease.mjs"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-opener": "^2",
    "lucide-react": "^1.14.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.13.3",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "jsdom": "^29.1.1",
    "typescript": "~5.8.3",
    "vite": "^7.0.4",
    "vitest": "^4.1.5"
  }
}
